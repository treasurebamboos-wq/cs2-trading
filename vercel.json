{
  "functions": {
    "api/sync.js": {
      "maxDuration": 60
    },
    "api/sync-steam.js": {
      "maxDuration": 60
    },
    "api/news.js": {
      "maxDuration": 30
    },
    "api/rarity-fix.js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET" }
      ]
    }
  ]
}
